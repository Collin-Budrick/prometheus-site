# Core runtime defaults
PROMETHEUS_WEB_HOST=prometheus.dev
PROMETHEUS_WEB_HOST_PROD=prometheus.prod
PROMETHEUS_DB_HOST=db.prometheus.dev
PROMETHEUS_DB_HOST_PROD=db.prometheus.prod
COMPOSE_PROJECT_NAME=prometheus
PROMETHEUS_COMPOSE_PROFILE=
PROMETHEUS_ENABLE_REALTIME_SERVICES=0

# Ports and local service exposure
PROMETHEUS_HTTP_PORT=80
PROMETHEUS_HTTPS_PORT=443
PROMETHEUS_API_PORT=4000
PROMETHEUS_SPACETIMEDB_PORT=3000
PROMETHEUS_GARNET_PORT=6379
PROMETHEUS_WEBTRANSPORT_PORT=4444
PROMETHEUS_DEVICE_WEB_PORT=4173

# Garnet tuning (cache-first, low-latency defaults)
PROMETHEUS_GARNET_MEMORY=1g
PROMETHEUS_GARNET_INDEX=256m
PROMETHEUS_GARNET_OBJ_LOG_MEMORY=64m
PROMETHEUS_GARNET_OBJ_INDEX=32m
PROMETHEUS_GARNET_MUTABLE_PERCENT=95
PROMETHEUS_GARNET_OBJ_MUTABLE_PERCENT=95
# Garnet read cache requires storage tiering; keep it off for the in-memory profile.
PROMETHEUS_GARNET_READCACHE=false
PROMETHEUS_GARNET_READCACHE_MEMORY=256m
PROMETHEUS_GARNET_READCACHE_PAGE=16m
PROMETHEUS_GARNET_OBJ_READCACHE=false
PROMETHEUS_GARNET_OBJ_READCACHE_LOG_MEMORY=64m
PROMETHEUS_GARNET_OBJ_READCACHE_PAGE=1m
PROMETHEUS_GARNET_COPY_READS_TO_TAIL=true
PROMETHEUS_GARNET_OBJ_COPY_READS_TO_TAIL=true
PROMETHEUS_GARNET_WORKER_THREADS=
PROMETHEUS_GARNET_IO_THREADS=

# Caddy and TLS artifacts
PROMETHEUS_CADDY_CERT_BASENAME=prometheus.dev+prometheus.prod+db.prometheus.dev+db.prometheus.prod

# Feature toggles used by compose + runtime
VITE_ENABLE_PREFETCH=1
VITE_ENABLE_WEBTRANSPORT_FRAGMENTS=1
VITE_ENABLE_WEBTRANSPORT_DATAGRAMS=1
VITE_ENABLE_FRAGMENT_COMPRESSION=1
VITE_ENABLE_PARTYTOWN=0
VITE_PARTYTOWN_FORWARD=
VITE_ENABLE_ANALYTICS=1
VITE_ENABLE_HIGHLIGHT=0
VITE_HIGHLIGHT_SAMPLE_RATE=0.1

ENABLE_WEBTRANSPORT_FRAGMENTS=1
WEBTRANSPORT_ENABLE_DATAGRAMS=1
WEBTRANSPORT_MAX_DATAGRAM_SIZE=1200

# API/runtime behavior
VITE_PUBLIC_BASE=
PROMETHEUS_VITE_API_BASE=/api
PROMETHEUS_VITE_WEBTRANSPORT_BASE=
FRAGMENT_PLAN_TTL=180
FRAGMENT_PLAN_STALE_TTL=300
FRAGMENT_INITIAL_TTL=180

# App runtime
PROMETHEUS_DEVICE_HOST=
API_BASE=
VITE_API_BASE=
VITE_WEBTRANSPORT_BASE=
WEBTRANSPORT_ALLOWED_ORIGINS=https://prometheus.dev,https://prometheus.prod
SPACETIMEDB_MODULE=prometheus-site-local
SPACETIMEDB_URI=http://127.0.0.1:3000
VITE_SPACETIMEDB_URI=https://db.prometheus.dev
VITE_SPACETIMEDB_MODULE=prometheus-site-local
SPACETIMEAUTH_AUTHORITY=https://auth.spacetimedb.com/oidc
SPACETIMEAUTH_CLIENT_ID=prometheus-site-dev
SPACETIMEAUTH_JWKS_URI=https://auth.spacetimedb.com/oidc/jwks
SPACETIMEAUTH_POST_LOGOUT_REDIRECT_URI=https://prometheus.dev/
VITE_SPACETIMEAUTH_AUTHORITY=https://auth.spacetimedb.com/oidc
VITE_SPACETIMEAUTH_CLIENT_ID=prometheus-site-dev
