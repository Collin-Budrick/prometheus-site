{
  "ignorePatterns": ["dist/**", "node_modules/**"],
  "env": {
    "es2022": true,
    "node": true
  },
  "overrides": [
    {
      "files": ["packages/core/**/*.{ts,tsx}"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": [
                  "@platform",
                  "@platform/*",
                  "@ui",
                  "@ui/*",
                  "packages/platform/**",
                  "packages/ui/**",
                  "../platform/**",
                  "../ui/**",
                  "../../platform/**",
                  "../../ui/**"
                ],
                "message": "Core must stay independent from platform, UI, and feature layers."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["apps/site/**/*.{ts,tsx}"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": [
                  "@platform/features/**",
                  "../../packages/platform/src/features/**",
                  "../packages/platform/src/features/**"
                ],
                "message": "Site-specific features belong under apps/site/src/features and server features belong under packages/platform/src/features."
              }
            ]
          }
        ]
      }
    }
  ]
}
