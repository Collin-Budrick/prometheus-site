# syntax=docker/dockerfile:1.5
FROM oven/bun:1.3.11-alpine AS deps
WORKDIR /app

COPY package.json bun.lock ./
COPY apps/site/package.json apps/site/package.json
COPY packages/core/package.json packages/core/package.json
COPY packages/platform/package.json packages/platform/package.json
COPY packages/spacetimedb-client/package.json packages/spacetimedb-client/package.json
COPY packages/template-config/package.json packages/template-config/package.json
COPY packages/ui/package.json packages/ui/package.json
RUN --mount=type=cache,target=/root/.bun/install/cache \
    bun install --ignore-scripts --filter site \
    || (echo "Workspace-filtered site install failed; falling back to full workspace install" && bun install --ignore-scripts)

FROM oven/bun:1.3.11-alpine AS builder
WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/package.json ./package.json
COPY --from=deps /app/apps ./apps
COPY --from=deps /app/packages ./packages

COPY tsconfig.base.json ./tsconfig.base.json
COPY apps/site ./apps/site
COPY packages ./packages
COPY scripts ./scripts
ARG VITE_API_BASE=/api
ARG VITE_AUTH_BASE_PATH
ARG VITE_AUTH_SOCIAL_PROVIDERS
ARG VITE_ENABLE_PREFETCH
ARG VITE_ENABLE_WEBTRANSPORT_FRAGMENTS
ARG VITE_ENABLE_WEBTRANSPORT_DATAGRAMS
ARG VITE_ENABLE_FRAGMENT_COMPRESSION
ARG VITE_ENABLE_ANALYTICS
ARG VITE_ENABLE_HIGHLIGHT
ARG VITE_HIGHLIGHT_PROJECT_ID
ARG VITE_HIGHLIGHT_PRIVACY
ARG VITE_HIGHLIGHT_SESSION_RECORDING
ARG VITE_HIGHLIGHT_CANVAS_SAMPLING
ARG VITE_HIGHLIGHT_SAMPLE_RATE
ARG VITE_WEBTRANSPORT_BASE
ARG VITE_P2P_CRDT_SIGNALING
ARG VITE_P2P_RELAY_BASES
ARG VITE_P2P_NOSTR_RELAYS
ARG VITE_P2P_WAKU_RELAYS
ARG VITE_P2P_PEERJS_SERVER
ARG VITE_PUBLIC_BASE
ARG VITE_DISABLE_SW
ARG VITE_OIDC_AUTHORITY
ARG VITE_OIDC_CLIENT_ID
ARG VITE_OIDC_JWKS_URI
ARG VITE_OIDC_POST_LOGOUT_REDIRECT_URI
ARG VITE_SPACETIMEAUTH_AUTHORITY
ARG VITE_SPACETIMEAUTH_CLIENT_ID
ARG VITE_SPACETIMEAUTH_POST_LOGOUT_REDIRECT_URI
ARG VITE_SPACETIMEDB_URI
ARG VITE_SPACETIMEDB_MODULE
ARG VITE_TEMPLATE_PRESET
ARG VITE_TEMPLATE_HOME_MODE
ARG VITE_TEMPLATE_FEATURES
ARG VITE_TEMPLATE_DISABLE_FEATURES
ARG PROMETHEUS_TEMPLATE_PRESET
ARG PROMETHEUS_TEMPLATE_HOME_MODE
ARG PROMETHEUS_TEMPLATE_FEATURES
ARG PROMETHEUS_TEMPLATE_DISABLE_FEATURES
ENV VITE_API_BASE=$VITE_API_BASE
ENV VITE_AUTH_BASE_PATH=$VITE_AUTH_BASE_PATH
ENV VITE_AUTH_SOCIAL_PROVIDERS=$VITE_AUTH_SOCIAL_PROVIDERS
ENV VITE_ENABLE_PREFETCH=$VITE_ENABLE_PREFETCH
ENV VITE_ENABLE_WEBTRANSPORT_FRAGMENTS=$VITE_ENABLE_WEBTRANSPORT_FRAGMENTS
ENV VITE_ENABLE_WEBTRANSPORT_DATAGRAMS=$VITE_ENABLE_WEBTRANSPORT_DATAGRAMS
ENV VITE_ENABLE_FRAGMENT_COMPRESSION=$VITE_ENABLE_FRAGMENT_COMPRESSION
ENV VITE_ENABLE_ANALYTICS=$VITE_ENABLE_ANALYTICS
ENV VITE_ENABLE_HIGHLIGHT=$VITE_ENABLE_HIGHLIGHT
ENV VITE_HIGHLIGHT_PROJECT_ID=$VITE_HIGHLIGHT_PROJECT_ID
ENV VITE_HIGHLIGHT_PRIVACY=$VITE_HIGHLIGHT_PRIVACY
ENV VITE_HIGHLIGHT_SESSION_RECORDING=$VITE_HIGHLIGHT_SESSION_RECORDING
ENV VITE_HIGHLIGHT_CANVAS_SAMPLING=$VITE_HIGHLIGHT_CANVAS_SAMPLING
ENV VITE_HIGHLIGHT_SAMPLE_RATE=$VITE_HIGHLIGHT_SAMPLE_RATE
ENV VITE_WEBTRANSPORT_BASE=$VITE_WEBTRANSPORT_BASE
ENV VITE_P2P_CRDT_SIGNALING=$VITE_P2P_CRDT_SIGNALING
ENV VITE_P2P_RELAY_BASES=$VITE_P2P_RELAY_BASES
ENV VITE_P2P_NOSTR_RELAYS=$VITE_P2P_NOSTR_RELAYS
ENV VITE_P2P_WAKU_RELAYS=$VITE_P2P_WAKU_RELAYS
ENV VITE_P2P_PEERJS_SERVER=$VITE_P2P_PEERJS_SERVER
ENV VITE_PUBLIC_BASE=$VITE_PUBLIC_BASE
ENV VITE_DISABLE_SW=$VITE_DISABLE_SW
ENV VITE_OIDC_AUTHORITY=$VITE_OIDC_AUTHORITY
ENV VITE_OIDC_CLIENT_ID=$VITE_OIDC_CLIENT_ID
ENV VITE_OIDC_JWKS_URI=$VITE_OIDC_JWKS_URI
ENV VITE_OIDC_POST_LOGOUT_REDIRECT_URI=$VITE_OIDC_POST_LOGOUT_REDIRECT_URI
ENV VITE_SPACETIMEAUTH_AUTHORITY=$VITE_SPACETIMEAUTH_AUTHORITY
ENV VITE_SPACETIMEAUTH_CLIENT_ID=$VITE_SPACETIMEAUTH_CLIENT_ID
ENV VITE_SPACETIMEAUTH_POST_LOGOUT_REDIRECT_URI=$VITE_SPACETIMEAUTH_POST_LOGOUT_REDIRECT_URI
ENV VITE_SPACETIMEDB_URI=$VITE_SPACETIMEDB_URI
ENV VITE_SPACETIMEDB_MODULE=$VITE_SPACETIMEDB_MODULE
ENV VITE_TEMPLATE_PRESET=$VITE_TEMPLATE_PRESET
ENV VITE_TEMPLATE_HOME_MODE=$VITE_TEMPLATE_HOME_MODE
ENV VITE_TEMPLATE_FEATURES=$VITE_TEMPLATE_FEATURES
ENV VITE_TEMPLATE_DISABLE_FEATURES=$VITE_TEMPLATE_DISABLE_FEATURES
ENV PROMETHEUS_TEMPLATE_PRESET=$PROMETHEUS_TEMPLATE_PRESET
ENV PROMETHEUS_TEMPLATE_HOME_MODE=$PROMETHEUS_TEMPLATE_HOME_MODE
ENV PROMETHEUS_TEMPLATE_FEATURES=$PROMETHEUS_TEMPLATE_FEATURES
ENV PROMETHEUS_TEMPLATE_DISABLE_FEATURES=$PROMETHEUS_TEMPLATE_DISABLE_FEATURES
RUN --mount=type=cache,target=/root/.bun/install/cache \
    --mount=type=cache,target=/root/.cache \
    bun run --cwd apps/site build

FROM oven/bun:1.3.11-alpine AS runner
WORKDIR /app/apps/site

ENV API_BASE=http://api:4000
ENV HOST=0.0.0.0
ENV PORT=4173
ENV PROMETHEUS_TEMPLATE_PRESET=
ENV PROMETHEUS_TEMPLATE_HOME_MODE=
ENV PROMETHEUS_TEMPLATE_FEATURES=
ENV PROMETHEUS_TEMPLATE_DISABLE_FEATURES=

COPY --from=deps /app/node_modules /app/node_modules
COPY --from=builder /app/apps/site/package.json ./package.json
COPY --from=builder /app/apps/site/vite.config.ts ./vite.config.ts
COPY --from=builder /app/apps/site/dist ./dist
COPY --from=builder /app/apps/site/server ./server
COPY --from=builder /app/apps/site/public ./public
COPY --from=builder /app/apps/site/src ./src
COPY --from=builder /app/apps/site/scripts ./scripts
COPY --from=builder /app/scripts /app/scripts
COPY --from=builder /app/tsconfig.base.json /app/tsconfig.base.json
COPY --from=builder /app/packages/platform/src/config.ts /app/packages/platform/src/config.ts
COPY --from=builder /app/packages/template-config /app/packages/template-config

EXPOSE 4173
CMD ["bun", "run", "scripts/serve-preview.mjs"]
