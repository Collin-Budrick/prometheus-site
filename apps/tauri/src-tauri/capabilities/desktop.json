{
  "$schema": "https://schema.tauri.app/schema/2/core/capabilities.json",
  "identifier": "desktop-main",
  "description": "Desktop capability profile for Prometheus native shell",
  "windows": ["main"],
  "platforms": ["windows", "macOS", "linux"],
  "permissions": [
    "core:default",
    "core:event:default",
    "deep-link:default",
    "shell:default",
    "dialog:default",
    "notification:default",
    "fs:default",
    "sql:default",
    "sql:allow-execute",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister-all",
    "updater:default"
  ]
}
