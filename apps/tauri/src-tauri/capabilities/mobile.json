{
  "$schema": "https://schema.tauri.app/schema/2/core/capabilities.json",
  "identifier": "mobile-main",
  "description": "Mobile capability profile for Prometheus native shell",
  "windows": ["main"],
  "platforms": ["android", "iOS"],
  "permissions": [
    "core:default",
    "core:event:default",
    "deep-link:default",
    "shell:default",
    "dialog:default",
    "notification:default",
    "fs:default",
    "sql:default",
    "sql:allow-execute"
  ]
}
