{
  "identifier": "com.prometheus.app",
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["prometheus"]
      },
      "mobile": [
        {
          "schemes": ["prometheus"],
          "host": "open"
        }
      ]
    },
    "updater": {
      "active": true,
      "endpoints": [],
      "pubkey": ""
    }
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; connect-src 'self' https: wss:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    }
  }
}
