{
  "name": "prometheus-site",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.3.10",
  "description": "Performance-forward monorepo for Qwik frontend and Bun Elysia API services.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:core": "PROMETHEUS_TEMPLATE_PRESET=core bun run scripts/dev.ts",
    "dev": "bun run scripts/dev.ts",
    "template:init": "bun run scripts/template-init.ts",
    "template:sync": "bun run scripts/template-sync.ts",
    "_internal:build:fragment-css": "bun run scripts/fragment-css.ts",
    "_internal:build:site": "bun run _internal:build:fragment-css && bun run --cwd apps/site build",
    "_internal:build:api": "bun run --cwd packages/platform build",
    "build:core": "PROMETHEUS_TEMPLATE_PRESET=core bun run build",
    "build": "bun run _internal:build:site && bun run _internal:build:api",
    "preview": "bun run _internal:preview",
    "_internal:preview": "bun run _internal:build:fragment-css && PROMETHEUS_DEVICE_HOST=0 bun run scripts/preview.ts",
    "_internal:dev:site": "bun run --cwd apps/site dev",
    "_internal:dev:api": "bun run --cwd packages/platform dev",
    "_internal:dev:storybook": "bun run --cwd apps/site storybook",
    "_internal:build:storybook": "bun run --cwd apps/site build-storybook",
    "_internal:bench:initial-route": "bun run scripts/benchmark-initial-route.ts",
    "_internal:lint:workspace": "bun x oxlint packages apps/site --config .oxlintrc.json",
    "_internal:lint:api": "bun run --cwd packages/platform lint",
    "_internal:lint:web": "bun run --cwd apps/site lint",
    "_internal:lint": "bun run --parallel _internal:lint:workspace _internal:lint:api _internal:lint:web",
    "_internal:check:decorators": "bun run scripts/check-decorators.ts",
    "check:template": "bun run template:sync --check && bun run scripts/check-template-branding.ts && bun run scripts/check-generated-artifacts.ts",
    "_internal:typecheck:platform": "bun run --cwd packages/platform tsc -p tsconfig.json --noEmit",
    "_internal:typecheck:site": "bun run --cwd apps/site tsc -p tsconfig.json --noEmit",
    "_internal:typecheck:storybook": "bun run --cwd apps/site tsc -p .storybook/tsconfig.json --noEmit",
    "_internal:typecheck:template-config": "bun run --cwd packages/template-config tsc -p tsconfig.json --noEmit",
    "_internal:typecheck:core": "bun run --cwd packages/core tsc -p tsconfig.json --noEmit",
    "_internal:typecheck:ui": "bun run --cwd packages/ui tsc -p tsconfig.json --noEmit",
    "_internal:typecheck:spacetimedb-client": "bun run --cwd packages/spacetimedb-client tsc -p tsconfig.json --noEmit",
    "_internal:typecheck": "bun run --parallel _internal:typecheck:platform _internal:typecheck:site _internal:typecheck:storybook _internal:typecheck:template-config _internal:typecheck:core _internal:typecheck:ui _internal:typecheck:spacetimedb-client",
    "typecheck:core": "PROMETHEUS_TEMPLATE_PRESET=core bun run typecheck",
    "typecheck": "bun run _internal:build:fragment-css && bun run _internal:typecheck",
    "_internal:format": "bun run --cwd packages/platform format",
    "_internal:test:retry": "bun run --cwd packages/platform test:retry",
    "test:core": "PROMETHEUS_TEMPLATE_PRESET=core bun run test",
    "test:browser:full": "bun run scripts/test-browser.ts full",
    "test:browser:core": "bun run scripts/test-browser.ts core",
    "test": "bun run --cwd packages/platform test",
    "_internal:hooks:install": "git config core.hooksPath .githooks"
  },
  "optionalDependencies": {
    "@oxlint/binding-linux-arm64-gnu": "1.56.0",
    "@oxfmt/win32-arm64": "0.28.0",
    "lefthook-linux-arm64": "2.1.4",
    "lefthook-windows-arm64": "2.1.4"
  },
  "devDependencies": {
    "@oxlint-tsgolint/linux-arm64": "0.17.1",
    "@oxlint-tsgolint/win32-arm64": "0.17.1",
    "@oxlint/win32-arm64": "1.43.0",
    "@playwright/test": "1.59.0-alpha-2026-03-21",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/web-push": "3.6.4",
    "bun-types": "^1.3.11",
    "lefthook": "^2.1.4",
    "oxlint": "1.56.0",
    "oxlint-tsgolint": "0.17.1",
    "typescript": "6.0.1-rc",
    "vite": "8.0.0-beta.18"
  }
}
