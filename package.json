{
  "name": "prometheus-site",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.3.11",
  "description": "Performance-forward monorepo for a Qwik frontend and consolidated Rust API/WebTransport service.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:core": "PROMETHEUS_TEMPLATE_PRESET=core bun ./scripts/runtime.ts dev",
    "dev": "bun ./scripts/runtime.ts dev",
    "desktop:dev": "bun run --cwd apps/desktop dev",
    "desktop:run": "bun run --cwd apps/desktop run",
    "desktop:build": "bun run --cwd apps/desktop build",
    "desktop:build:canary": "bun run --cwd apps/desktop build:canary",
    "desktop:build:stable": "bun run --cwd apps/desktop build:stable",
    "desktop:typecheck": "bun run --cwd apps/desktop typecheck",
    "template:init": "bun run scripts/template.ts init",
    "template:new": "bun run scripts/template.ts new",
    "template:sync": "bun run scripts/template.ts sync",
    "template:doctor": "bun run scripts/template.ts doctor",
    "template:diff": "bun run scripts/template.ts diff",
    "template:report": "bun run scripts/template.ts report",
    "template:upgrade": "bun run scripts/template.ts upgrade",
    "template:create-feature": "bun run scripts/template.ts create-feature",
    "_internal:build:fragment-css": "bun run scripts/fragment-css.ts",
    "_internal:build:site": "bun run _internal:build:fragment-css && bun run --cwd apps/site build",
    "_internal:build:api": "cargo build --manifest-path packages/platform-rs/Cargo.toml --locked --release",
    "build:core": "PROMETHEUS_TEMPLATE_PRESET=core bun run build",
    "build": "bun run _internal:build:site && bun run _internal:build:api",
    "preview": "bun run _internal:preview",
    "_internal:preview": "PROMETHEUS_DEVICE_HOST=0 bun ./scripts/runtime.ts preview",
    "_internal:dev:site": "bun run --cwd apps/site dev",
    "_internal:dev:api": "cargo run --manifest-path packages/platform-rs/Cargo.toml --locked",
    "_internal:dev:storybook": "bun run --cwd apps/site storybook",
    "_internal:build:storybook": "bun run --cwd apps/site build-storybook",
    "_internal:bench:initial-route": "node --experimental-strip-types scripts/benchmark-initial-route.ts",
    "_internal:lint:workspace": "bun x oxlint packages apps --config .oxlintrc.json",
    "_internal:lint:api": "cargo fmt --manifest-path packages/platform-rs/Cargo.toml --check",
    "_internal:lint:web": "bun run --cwd apps/site lint",
    "_internal:lint": "bun run --parallel _internal:lint:workspace _internal:lint:api _internal:lint:web",
    "_internal:check:decorators": "bun run scripts/check-decorators.ts",
    "check:template": "bun run scripts/template.ts check",
    "_internal:typecheck:platform": "bun run --cwd packages/platform tsc -p tsconfig.json --noEmit",
    "_internal:typecheck:site": "bun run --cwd apps/site tsc -p tsconfig.json --noEmit",
    "_internal:typecheck:desktop": "bun run --cwd apps/desktop typecheck",
    "_internal:typecheck:storybook": "bun run --cwd apps/site tsc -p .storybook/tsconfig.json --noEmit",
    "_internal:typecheck:template-config": "bun run --cwd packages/template-config tsc -p tsconfig.json --noEmit",
    "_internal:typecheck:core": "bun run --cwd packages/core tsc -p tsconfig.json --noEmit",
    "_internal:typecheck:ui": "bun run --cwd packages/ui tsc -p tsconfig.json --noEmit",
    "_internal:typecheck:spacetimedb-client": "bun run --cwd packages/spacetimedb-client tsc -p tsconfig.json --noEmit",
    "_internal:typecheck:platform-rs": "cargo check --manifest-path packages/platform-rs/Cargo.toml --locked",
    "_internal:typecheck": "bun run --parallel _internal:typecheck:platform _internal:typecheck:site _internal:typecheck:desktop _internal:typecheck:storybook _internal:typecheck:template-config _internal:typecheck:core _internal:typecheck:ui _internal:typecheck:spacetimedb-client _internal:typecheck:platform-rs",
    "typecheck:core": "PROMETHEUS_TEMPLATE_PRESET=core bun run typecheck",
    "typecheck": "bun run _internal:build:fragment-css && bun run _internal:typecheck",
    "_internal:format": "cargo fmt --manifest-path packages/platform-rs/Cargo.toml",
    "_internal:test:retry": "cargo test --manifest-path packages/platform-rs/Cargo.toml --locked",
    "test:core": "PROMETHEUS_TEMPLATE_PRESET=core bun run test",
    "test:browser:full": "bun ./scripts/runtime.ts browser full",
    "test:browser:core": "bun ./scripts/runtime.ts browser core",
    "test": "cargo test --manifest-path packages/platform-rs/Cargo.toml --locked",
    "_internal:hooks:install": "git config core.hooksPath .githooks"
  },
  "optionalDependencies": {
    "@oxlint/binding-linux-arm64-gnu": "1.57.0",
    "@oxfmt/win32-arm64": "0.28.0",
    "lefthook-linux-arm64": "2.1.4",
    "lefthook-windows-arm64": "2.1.4"
  },
  "devDependencies": {
    "@oxlint-tsgolint/linux-arm64": "0.18.1",
    "@oxlint-tsgolint/win32-arm64": "0.18.1",
    "@oxlint/win32-arm64": "1.43.0",
    "@playwright/test": "1.59.0-alpha-2026-03-29",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/web-push": "3.6.4",
    "bun-types": "^1.3.11",
    "lefthook": "^2.1.4",
    "oxlint": "1.57.0",
    "oxlint-tsgolint": "0.18.1",
    "typescript": "6.0.2",
    "vite": "8.0.3"
  },
  "dependencies": {
    "@better-auth/cli": "1.5.0-beta.13",
    "@better-auth/passkey": "1.5.7-beta.1",
    "@convex-dev/better-auth": "0.11.4",
    "better-auth": "1.5.7-beta.1",
    "convex": "^1.34.1"
  }
}
