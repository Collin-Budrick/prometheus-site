{
  "name": "@prometheus/platform",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.3.10"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "types": "./src/index.ts",
  "scripts": {
    "dev": "bun run --watch src/entrypoints/api.ts",
    "build": "bun build src/entrypoints/api.ts --target bun --outfile dist/index.js",
    "lint": "bun x oxlint .",
    "format": "oxfmt --write .",
    "test": "bun test tests",
    "test:retry": "bun test --retry 3 tests"
  },
  "dependencies": {
    "@logtape/logtape": "2.1.0-dev.522",
    "@prometheus/core": "workspace:*",
    "@prometheus/features-auth": "workspace:*",
    "@prometheus/features-messaging": "workspace:*",
    "@prometheus/features-store": "workspace:*",
    "@prometheus/template-config": "workspace:*",
    "@unkey/ratelimit": "2.1.4",
    "@valkey/client": "1.0.0",
    "arkenv": "0.11.0",
    "arktype": "2.2.0",
    "elysia": "1.4.28",
    "highlight.run": "9.27.1",
    "loro-crdt": "1.10.7",
    "react": "19.3.0-canary-fd524fe0-20251121",
    "web-push": "3.6.7",
    "zod": "4.4.0-canary.20260125T215152"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "bun-types": "1.3.11-canary.20260319T142214",
    "oxfmt": "0.41.0",
    "oxlint": "1.56.0",
    "typescript": "6.0.1-rc"
  },
  "optionalDependencies": {
    "@oxlint/win32-arm64": "1.43.0"
  }
}
