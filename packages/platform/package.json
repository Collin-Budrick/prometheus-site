{
  "name": "@prometheus/platform",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.3.10"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "types": "./src/index.ts",
  "scripts": {
    "dev": "bun run --watch src/entrypoints/api.ts",
    "build": "bun build src/entrypoints/api.ts --target bun --outfile dist/index.js",
    "lint": "bun x oxlint .",
    "format": "oxfmt --write .",
    "test": "bun test tests",
    "test:retry": "bun test --retry 3 tests",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:prepare": "RUN_MIGRATIONS=1 bun run src/db/prepare-cli.ts",
    "db:seed": "bun run src/db/seed.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts"
  },
  "dependencies": {
    "@logtape/logtape": "^2.1.0-dev.501",
    "@prometheus/core": "workspace:*",
    "@prometheus/features-auth": "workspace:*",
    "@prometheus/features-messaging": "workspace:*",
    "@prometheus/features-store": "workspace:*",
    "@unkey/ratelimit": "2.1.4",
    "@valkey/client": "1.0.0",
    "arkenv": "0.11.0",
    "arktype": "2.2.0",
    "drizzle-orm": "1.0.0-beta.9-e89174b",
    "drizzle-zod": "1.0.0-beta.9-e89174b",
    "elysia": "1.4.27",
    "highlight.run": "9.27.1",
    "postgres": "3.4.8",
    "react": "19.3.0-canary-fd524fe0-20251121",
    "web-push": "3.6.7",
    "zod": "4.4.0-canary.20260125T215152"
  },
  "devDependencies": {
    "@types/node": "25.4.0",
    "@types/react": "19.2.14",
    "bun-types": "1.3.11-canary.20260310T142154",
    "drizzle-kit": "1.0.0-beta.9-e89174b",
    "oxfmt": "0.37.0",
    "oxlint": "1.52.0",
    "typescript": "6.0.1-rc"
  },
  "optionalDependencies": {
    "@oxlint/win32-arm64": "1.43.0"
  }
}
